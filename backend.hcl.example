# backend.hcl.example
# Copy to backend.hcl and fill in MinIO credentials before:
#   terraform init -backend-config=backend.hcl
# backend.hcl is excluded by .gitignore — never commit it.

bucket   = "platform-terraform-state"
key      = "platform-services/terraform.tfstate"
region   = "us-east-1"
endpoint = "http://localhost:9000"   # MinIO from platform-infrastructure

access_key = ""   # MinIO access key
secret_key = ""   # MinIO secret key

skip_credentials_validation = true
skip_metadata_api_check     = true
skip_region_validation      = true
force_path_style            = true
